# ==============================================================================
# 🧠 TEC-BRAIN CONFIGURATION - .env.example
# Copia este archivo como .env y reemplaza los valores "CHANGE_ME"
# ==============================================================================

# ─── 1. Base de Datos (PostgreSQL) ────────────────────────────────────────────
# Si usas docker-compose, esta URL conectará localmente.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/tecbrain
POSTGRES_PASSWORD=postgres

# ─── 2. Encriptación (AES-256) ────────────────────────────────────────────────
# Obligatorio: Clave Hexadecimal de 64 caracteres.
# Generador rápido en terminal: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
DB_ENCRYPTION_KEY=CHANGE_ME_PIEGA_AQUI_TUS_64_CARACTERES_HEX

# ─── 3. Telegram Bot ──────────────────────────────────────────────────────────
# Abre botfather en Telegram y envía /newbot para obtener el Token.
TELEGRAM_BOT_TOKEN=CHANGE_ME_TU_TOKEN_DE_BOTFATHER

# ─── 4. Google Drive (OAuth) ──────────────────────────────────────────────────
# Ve a Google Cloud > Credentials > Crea credenciales OAuth 2.0 (Web application).
# Coloca el archivo JSON descargado en ./data/credentials/ y pon su nombre aquí.
GOOGLE_DRIVE_CREDENTIALS_PATH=./data/credentials/credentials.json
# Si el servidor no corre en localhost, define la URL pública del callback OAuth.
# Debe estar añadida también en "Authorized redirect URIs" en Google Cloud Console.
# Ejemplo: https://mi-servidor.com/auth/drive/callback
OAUTH_REDIRECT_URI=

# ─── 4b. OneDrive (OAuth) ─────────────────────────────────────────────────────
# Crea una app en Azure Portal (Microsoft Entra ID) y habilita permisos Files.ReadWrite.
ONEDRIVE_CLIENT_ID=
ONEDRIVE_CLIENT_SECRET=
# Ejemplo: https://mi-servidor.com/auth/onedrive/callback
ONEDRIVE_REDIRECT_URI=

# ─── 5. Secretos internos (OBLIGATORIO en producción) ────────────────────────
# Clave compartida entre core y scraper para autenticar llamadas internas.
# Genera una con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INTERNAL_API_SECRET=CHANGE_ME_SECRET_INTERNO_HEX
# Clave compartida entre core (orchestrator) y el scraper.
SCRAPER_SECRET=CHANGE_ME_SCRAPER_SECRET_HEX

# ─── 6. Core Orchestrator ─────────────────────────────────────────────────────
# Frecuencia de chequeo (Cron) - Default: Cada 5 minutos
CRON_SCHEDULE="*/5 * * * *"
# Límite de extracciones paralelas para no saturar al TEC (Default: 3)
CORE_CONCURRENCY=3
# URL interna del Scraper (No cambiar si usas Docker)
SCRAPER_URL=http://localhost:3001
# Reintentos HTTP para endpoints TEC/Core/Drive
HTTP_RETRY_ATTEMPTS=3
HTTP_RETRY_BASE_MS=400
# Alertas automaticas por ciclo (core)
ALERT_PARTIAL_THRESHOLD_PCT=20
ALERT_USER_FAILURES_THRESHOLD=1
# Chat ID administrador para alertas (opcional)
ADMIN_ALERT_CHAT_ID=

# ─── 7. Scraper Service ───────────────────────────────────────────────────────
# Carpeta donde se guardan sesiones HTTP (cookies JSON) por usuario
SESSION_DIR=./data/sessions
# Horas máximas que se reutiliza una cookie antes de forzar relogin (default interno: 12)
SESSION_MAX_AGE_HOURS=12
PORT=3001

# ==============================================================================
# 🎯 SIGUIENTES PASOS AL CONFIGURAR ESTE ARCHIVO:
# 1. Asegúrate de tener docker-compose corriendo: `docker compose -f infra/docker-compose.yml up -d db`
# 2. Registra tu usuario en la Base de Datos usando este comando en tu terminal:
#
#    npx tsx scripts/add-user.ts "Tu Nombre" "correo@estudiantec.cr" "TuClaveReal123" "TuTelegramChatID" "TuCarpetaDriveID"
#
# * Para obtener "TuTelegramChatID": Escríbele a @RawDataBot en Telegram y copia tu id.
# * Para obtener "TuCarpetaDriveID": Crea una carpeta compartida con tu Service Account (Google Drive) y copia el ID de la URL.
# ==============================================================================
